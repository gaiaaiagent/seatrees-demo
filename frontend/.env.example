# Database (PostgreSQL — required for API routes)
DATABASE_URL=postgresql://postgres:password@localhost:5432/seatrees_demo

# Optional: point to standalone Fastify API (leave empty to use Next.js API routes)
NEXT_PUBLIC_API_URL=

# Regen Ledger API (live chain queries — used by ledger API routes)
# Default: queries polkachu directly from server-side routes
# Override if using a custom proxy (e.g., regen.gaiaai.xyz)
